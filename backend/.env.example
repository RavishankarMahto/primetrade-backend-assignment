# SQLite (simple local dev — no Docker)
DATABASE_URL="file:./dev.db"

# PostgreSQL (production / Docker — uncomment and set credentials)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/primetrade_assignment?schema=public"

JWT_SECRET="change-this-to-a-long-random-string-at-least-32-chars"
JWT_EXPIRES_IN="7d"
PORT=4000
NODE_ENV=development
CORS_ORIGIN="http://localhost:5173"
